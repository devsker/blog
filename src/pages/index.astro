---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const basePath = import.meta.env.BASE_URL;
const withBase = (path: string) =>
    `${basePath.replace(/\/$/, "")}/${path.replace(/^\//, "")}`;
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            .site-header {
                padding: 4rem 0 3.5rem;
            }

            .display-title {
                font-family: "Syne";
                font-weight: 800;
                font-size: clamp(2.75rem, 8vw, 4rem);
                line-height: 0.9;
                letter-spacing: -0.02em;
                margin: 0 0 1.25rem;
                color: var(--text);
            }

            .display-title::after {
                content: ".";
                color: var(--accent);
            }

            .site-description {
                color: var(--muted);
                font-size: 0.95rem;
                margin: 0;
                line-height: 1.5;
                max-width: 32rem;
            }

            .posts-heading {
                font-size: 0.75rem;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--faint);
                margin: 0 0 0.5rem;
            }

            ul {
                list-style: none;
                margin: 0;
                padding: 0;
            }

            li + li {
                border-top: 1px solid var(--border);
            }

            a.post-link {
                display: block;
                padding: 1.15rem 0;
                text-decoration: none;
                color: var(--text);
            }

            .post-row {
                display: flex;
                align-items: baseline;
                gap: 1rem;
            }

            .post-title {
                flex: 1;
                font-size: 1rem;
                font-weight: 500;
                line-height: 1.4;
                transition: color 160ms ease;
            }

            a.post-link:hover .post-title {
                color: var(--accent);
            }

            .post-date {
                color: var(--faint);
                font-size: 0.8rem;
                font-variant-numeric: tabular-nums;
                white-space: nowrap;
            }

            .post-description {
                margin: 0.3rem 0 0;
                color: var(--muted);
                font-size: 0.875rem;
                line-height: 1.55;
                max-width: 36rem;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }
        </style>
    </head>
    <body>
        <main>
            <header class="site-header">
                <h1 class="display-title">blog</h1>
                <p class="site-description">{SITE_DESCRIPTION}</p>
            </header>
            <section>
                {posts.length > 0 && <p class="posts-heading">Posts</p>}
                <ul>
                    {
                        posts.map((post) => (
                            <li>
                                <a
                                    class="post-link"
                                    href={withBase(`posts/${post.id}/`)}
                                >
                                    <span class="post-row">
                                        <span class="post-title" transition:name={`post-title-${post.id}`}>
                                            {post.data.title}
                                        </span>
                                        <span class="post-date">
                                            <FormattedDate
                                                date={post.data.pubDate}
                                            />
                                        </span>
                                    </span>
                                    {post.data.description && (
                                        <p class="post-description">
                                            {post.data.description}
                                        </p>
                                    )}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>
        </main>
        <Footer />
    </body>
</html>
