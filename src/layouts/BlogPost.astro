---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import ArrowLeft02Icon from '@hugeicons/core-free-icons/ArrowLeft02Icon';
import Copy01Icon from '@hugeicons/core-free-icons/Copy01Icon';
import Link01Icon from '@hugeicons/core-free-icons/Link01Icon';
import Tick01Icon from '@hugeicons/core-free-icons/Tick01Icon';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	id: string;
	readingTime?: number;
	headings?: MarkdownHeading[];
};

const { id, title, description, pubDate, updatedDate, heroImage, readingTime, headings } = Astro.props;
const hasToc = headings && headings.filter((h) => h.depth === 2 || h.depth === 3).length > 1;

const basePath = import.meta.env.BASE_URL;
const withBase = (path: string) => `${basePath.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;

function renderIconMarkup(icon: Array<[string, Record<string, string>]>) {
	return `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true">${icon
		.map(
			([tag, attrs]) =>
				`<${tag} ${Object.entries(attrs)
					.map(([key, value]) => `${key}="${value}"`)
					.join(' ')}></${tag}>`,
		)
		.join('')}</svg>`;
}

const copyIconMarkup = renderIconMarkup(Copy01Icon);
const linkIconMarkup = renderIconMarkup(Link01Icon);
const copiedIconMarkup = renderIconMarkup(Tick01Icon);
const backIconMarkup = renderIconMarkup(ArrowLeft02Icon);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} imageAlt={title} type="article" />
		<style>
			/* ── Smart Layout ── */
			main {
				width: 100% !important;
				max-width: none !important;
				padding: 2.5rem 0 4rem !important;
			}

			.prose {
				display: grid;
				grid-template-columns: 1fr min(44rem, calc(100% - 2rem)) 1fr;
				padding-top: 0;
			}

			/* Everything in column 2 by default */
			.prose > :not(.sidebar) {
				grid-column: 2;
			}

			.sidebar {
				display: none;
			}

			@media (min-width: 72rem) {
				.prose.has-toc {
					grid-template-columns: 1fr 44rem 6rem 260px 1fr;
					column-gap: 0;
				}

				.sidebar {
					display: block;
					grid-column: 4;
					grid-row: 1 / span 1000;
					position: sticky;
					top: 2.5rem;
					height: fit-content;
					align-self: start;
				}
			}

			/* Handle mobile TOC display */
			@media (max-width: 71.99rem) {
				.prose.has-toc .sidebar {
					display: block;
					grid-column: 2;
					margin-bottom: 2rem;
					order: -1; /* Place above content but below title? Actually, let's keep it above hero image */
				}
			}

			/* ── Back link ── */
			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				margin-bottom: 2.5rem;
				color: var(--muted);
				text-decoration: none;
				font-size: 0.85rem;
				letter-spacing: 0.01em;
			}

			.back-link:hover {
				color: var(--accent);
			}

			.back-link__icon {
				display: inline-flex;
				align-items: center;
				justify-content: center;
			}

			.back-link__icon :global(svg) {
				width: 1rem;
				height: 1rem;
				transform: translateY(-1px);
			}

			.back-link__icon :global(svg *) {
				stroke-width: 2;
			}

			/* ── Post header ── */
			.title {
				margin-bottom: 3rem;
				padding-bottom: 2.25rem;
				position: relative;
			}

			.title::after {
				content: '';
				position: absolute;
				bottom: 0;
				left: 0;
				width: 3.5rem;
				height: 2px;
				background: var(--accent);
			}

			.title h1 {
				font-size: clamp(1.75rem, 4.5vw, 2.5rem);
				line-height: 1.12;
				font-weight: 700;
				margin-bottom: 0.85rem;
				letter-spacing: -0.015em;
			}

			.meta {
				color: var(--muted);
				font-size: 0.85rem;
				font-variant-numeric: tabular-nums;
				margin-bottom: 1rem;
			}

			.last-updated-on {
				color: var(--muted);
			}

			.description {
				color: var(--muted);
				font-size: 1rem;
				line-height: 1.5;
				margin: 0;
				font-style: italic;
			}

			/* ── Prose content ── */
			.content {
				font-family: 'Lora', Georgia, serif;
			}

			.content :global(p) {
				margin-bottom: 1.5rem;
				font-size: 1.05rem;
				line-height: 1.8;
				color: var(--text);
			}

			.content :global(h2) {
				font-family: 'Inter', system-ui, sans-serif;
				font-size: 1.2rem;
				font-weight: 700;
				margin: 2.75rem 0 0.75rem;
				letter-spacing: -0.01em;
			}

			.content :global(h3) {
				font-family: 'Inter', system-ui, sans-serif;
				font-size: 1rem;
				font-weight: 700;
				margin: 2rem 0 0.5rem;
				letter-spacing: -0.005em;
			}

			.content :global(ul),
			.content :global(ol) {
				padding-left: 1.5rem;
				margin-bottom: 1.5rem;
			}

			.content :global(li) {
				margin-bottom: 0.45rem;
				line-height: 1.75;
				font-size: 1.05rem;
			}

			.content :global(strong) {
				color: var(--text);
				font-weight: 700;
			}

			.content :global(a) {
				color: var(--text);
				text-decoration-color: var(--accent);
				text-decoration-thickness: 1px;
				text-underline-offset: 3px;
				transition: color 160ms ease;
			}

			.content :global(a:hover) {
				color: var(--accent);
			}

			.content :global(hr) {
				border: none;
				border-top: 1px solid var(--border);
				margin: 2.5rem 0;
			}

			.content :global(blockquote) {
				border-left: 2px solid var(--accent);
				padding-left: 1.25rem;
				margin: 1.75rem 0;
				color: var(--muted);
				font-style: italic;
			}

			.content :global(table) {
				width: 100%;
				border-collapse: collapse;
				margin: 1.75rem 0;
				font-family: 'Inter', system-ui, sans-serif;
				font-size: 0.875rem;
				line-height: 1.5;
			}

			.content :global(th),
			.content :global(td) {
				padding: 0.6rem 0.85rem;
				border: 1px solid var(--border);
				text-align: left;
				vertical-align: top;
			}

			.content :global(th) {
				font-weight: 600;
				background: var(--surface);
				color: var(--text);
			}

			.content :global(tr:nth-child(even) td) {
				background: color-mix(in srgb, var(--surface) 40%, transparent);
			}

			@media (max-width: 720px) {
				.content :global(table) {
					display: block;
					overflow-x: auto;
					-webkit-overflow-scrolling: touch;
				}
			}

			.content :global(pre) {
				position: relative;
				padding: 1.25rem;
				border-radius: 6px;
				border: 1px solid var(--border);
				background: var(--surface);
				overflow-x: auto;
				margin-bottom: 1.75rem;
				font-size: 0.85rem;
				line-height: 1.65;
				font-family: ui-monospace, 'Cascadia Code', monospace;
			}

			.content :global(code) {
				font-size: 0.875em;
				font-family: ui-monospace, 'Cascadia Code', monospace;
				background: var(--surface);
				padding: 2px 6px;
				border-radius: 3px;
			}

			.content :global(pre code) {
				background: transparent;
				padding: 0;
				font-size: inherit;
			}

			.content :global(.astro-code) {
				background: var(--surface) !important;
			}

			img {
				margin-bottom: 2rem;
				border-radius: 4px;
			}

			/* ── Embeds ── */
			.prose :global(.auto-embed) {
				margin: 2rem 0;
			}

			.prose :global(.auto-embed__frame) {
				display: block;
				width: 100%;
				aspect-ratio: 16 / 9;
				border: 0;
				border-radius: 4px;
				background: var(--surface);
			}

			.prose :global([src*='open.spotify.com/embed/']) {
				aspect-ratio: auto;
				min-height: 352px;
			}

			/* ── Heading anchors ── */
			.prose :global(.heading-anchor) {
				position: relative;
				scroll-margin-top: 1.5rem;
			}

			.prose :global(.heading-anchor__content) {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				flex-wrap: wrap;
			}

			.prose :global(.heading-anchor__link) {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 1rem;
				height: 1rem;
				padding: 0;
				color: var(--muted);
				text-decoration: none;
				opacity: 0;
				transform: translateX(-0.15rem);
				pointer-events: none;
				transition:
					opacity 160ms ease,
					color 160ms ease,
					transform 160ms ease;
			}

			.prose :global(.heading-anchor:hover .heading-anchor__link),
			.prose :global(.heading-anchor:focus-within .heading-anchor__link),
			.prose :global(.heading-anchor__link[data-copied='true']) {
				opacity: 1;
				pointer-events: auto;
				transform: translateX(0);
			}

			.prose :global(.heading-anchor__link:hover),
			.prose :global(.heading-anchor__link:focus-visible) {
				color: var(--accent);
			}

			.prose :global(.heading-anchor__link:focus-visible) {
				outline: 2px solid var(--text);
				outline-offset: 2px;
				border-radius: 3px;
			}

			.prose :global(.heading-anchor__link[data-copied='true']) {
				color: var(--accent);
				transform: scale(1.04);
			}

			.prose :global(.heading-anchor__link svg) {
				width: 1rem;
				height: 1rem;
			}

			/* ── Code copy button ── */
			.prose :global(.code-copy-button) {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				position: absolute;
				top: 0.75rem;
				right: 0.75rem;
				width: 1rem;
				height: 1rem;
				border: 0;
				padding: 0;
				background: transparent;
				color: color-mix(in srgb, white 50%, transparent);
				cursor: pointer;
				transition:
					color 160ms ease,
					transform 160ms ease;
			}

			.prose :global(.code-copy-button:hover) {
				color: white;
			}

			.prose :global(.code-copy-button:focus-visible) {
				outline: 2px solid var(--text);
				outline-offset: 2px;
			}

			.prose :global(.code-copy-button[data-copied='true']) {
				color: white;
				transform: scale(1.04);
			}

			.prose :global(.code-copy-button svg) {
				width: 1rem;
				height: 1rem;
			}
		</style>
	</head>

	<body>
		<main>
			<article class:list={['prose', hasToc && 'has-toc']}>
				<a class="back-link" href={withBase('/')}><span class="back-link__icon" aria-hidden="true" set:html={backIconMarkup} /> all posts</a>
				<div class="title">
					<h1 transition:name={`post-title-${id}`}>{title}</h1>
					<div class="meta">
						<FormattedDate date={pubDate} />
						{readingTime && <span>&nbsp;&middot; {readingTime} min read</span>}
						{
							updatedDate && (
								<span class="last-updated-on">
									&nbsp;&middot; updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
					{description && <p class="description">{description}</p>}
				</div>
				{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				<div class="content">
					<slot />
				</div>
				{
					hasToc && (
						<aside class="sidebar">
							<TableOfContents headings={headings!} />
						</aside>
					)
				}
			</article>
		</main>
		<Footer />
		<script is:inline define:vars={{ copyIconMarkup, linkIconMarkup, copiedIconMarkup }}>
			const slugify = (value) =>
				value
					.toLowerCase()
					.trim()
					.replace(/[^\w\s-]/g, '')
					.replace(/[\s_-]+/g, '-')
					.replace(/^-+|-+$/g, '');

			const copyText = async (text) => {
				if (navigator.clipboard?.writeText) {
					await navigator.clipboard.writeText(text);
					return;
				}

				const input = document.createElement('textarea');
				input.value = text;
				input.setAttribute('readonly', '');
				input.style.position = 'absolute';
				input.style.left = '-9999px';
				document.body.append(input);
				input.select();
				document.execCommand('copy');
				input.remove();
			};

			const enhanceHeading = (heading, usedIds) => {
				if (heading.querySelector('.heading-anchor__link')) {
					return;
				}

				const baseId = heading.id || slugify(heading.textContent || '') || 'section';
				let nextId = baseId;
				let duplicateIndex = 2;

				while (usedIds.has(nextId) && heading.id !== nextId) {
					nextId = `${baseId}-${duplicateIndex}`;
					duplicateIndex += 1;
				}

				heading.id = nextId;
				usedIds.add(nextId);
				heading.classList.add('heading-anchor');

				const wrapper = document.createElement('span');
				wrapper.className = 'heading-anchor__content';

				while (heading.firstChild) {
					wrapper.append(heading.firstChild);
				}

				const link = document.createElement('a');
				link.className = 'heading-anchor__link';
				link.setAttribute('aria-label', `Copy link to ${heading.textContent?.trim() || 'section'}`);
				link.innerHTML = linkIconMarkup;
				link.href = `#${heading.id}`;

				let resetTimer;
				link.addEventListener('click', async (event) => {
					event.preventDefault();
					const url = new URL(window.location.href);
					url.hash = heading.id;

					try {
						await copyText(url.toString());
						history.replaceState(null, '', `#${heading.id}`);
						link.innerHTML = copiedIconMarkup;
						link.dataset.copied = 'true';
						window.clearTimeout(resetTimer);
						resetTimer = window.setTimeout(() => {
							link.innerHTML = linkIconMarkup;
							link.dataset.copied = 'false';
						}, 2200);
					} catch {
						link.dataset.copied = 'false';
					}
				});

				wrapper.append(link);
				heading.append(wrapper);
			};

			const enhanceCodeBlock = (pre) => {
				if (pre.querySelector('.code-copy-button')) {
					return;
				}

				const code = pre.querySelector('code');
				if (!code?.textContent?.trim()) {
					return;
				}

				const button = document.createElement('button');
				button.type = 'button';
				button.className = 'code-copy-button';
				button.setAttribute('aria-label', 'Copy code block');
				button.innerHTML = copyIconMarkup;

				let resetTimer;
				button.addEventListener('click', async () => {
					try {
						await copyText(code.textContent ?? '');
						button.innerHTML = copiedIconMarkup;
						button.dataset.copied = 'true';
						window.clearTimeout(resetTimer);
						resetTimer = window.setTimeout(() => {
							button.innerHTML = copyIconMarkup;
							button.dataset.copied = 'false';
						}, 2200);
					} catch {
						button.dataset.copied = 'false';
					}
				});

				pre.append(button);
			};

			const usedIds = new Set();
			for (const heading of document.querySelectorAll('article.prose h2[id], article.prose h3[id]')) {
				if (heading.id) {
					usedIds.add(heading.id);
				}
			}

			for (const heading of document.querySelectorAll('article.prose h2, article.prose h3')) {
				enhanceHeading(heading, usedIds);
			}

			for (const pre of document.querySelectorAll('article.prose pre')) {
				enhanceCodeBlock(pre);
			}
		</script>
	</body>
</html>
