---
interface Props {
	cols?: 2 | 3;
}

const { cols = 2 } = Astro.props;
---

<div class="image-grid" data-cols={cols}>
	<slot />
</div>

<style>
	.image-grid {
		display: grid;
		gap: 0.75rem;
		margin: 2rem 0;
	}

	.image-grid[data-cols='2'] {
		grid-template-columns: repeat(2, 1fr);
	}

	.image-grid[data-cols='3'] {
		grid-template-columns: repeat(3, 1fr);
	}

	.image-grid :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 4px;
		border: 1px solid var(--border);
		margin-bottom: 0;
	}

	.image-grid :global(figure) {
		margin: 0;
	}

	@media (max-width: 540px) {
		.image-grid[data-cols='3'] {
			grid-template-columns: repeat(2, 1fr);
		}

		.image-grid[data-cols='2'] {
			grid-template-columns: 1fr;
		}
	}
</style>
