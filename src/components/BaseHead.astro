---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	imageAlt?: string;
	type?: 'website' | 'article';
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const basePath = import.meta.env.BASE_URL;
const withBase = (path: string) => `${basePath.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
const sitemapURL = new URL(withBase('sitemap-index.xml'), Astro.site);
const rssURL = new URL(withBase('rss.xml'), Astro.site);
const regularFontURL = withBase('fonts/atkinson-regular.woff');
const boldFontURL = withBase('fonts/atkinson-bold.woff');

const { title, description, image, imageAlt = description, type = 'website' } = Astro.props;
const defaultSocialImageURL = new URL(withBase('og/homepage-og.png'), Astro.site);
const socialImageURL = image ? new URL(image.src, Astro.site) : defaultSocialImageURL;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="theme-color" content="#111111" />
<link rel="sitemap" href={sitemapURL} />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={rssURL}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href={regularFontURL} as="font" type="font/woff" crossorigin />
<link rel="preload" href={boldFontURL} as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageURL} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageURL} />
<meta property="twitter:image:alt" content={imageAlt} />
