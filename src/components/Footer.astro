---
const today = new Date();
---

<footer>
    <p>&copy; {today.getFullYear()} sker</p>
</footer>
<style>
    footer {
        width: min(42rem, calc(100% - 2rem));
        margin: 0 auto;
        padding: 0 0 2.5rem;
        color: var(--muted);
    }

    p {
        margin: 0;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        font-size: 0.85rem;
    }
</style>
