---
const today = new Date();
---

<footer>
    <p>&copy; {today.getFullYear()} sker</p>
</footer>
<style>
    footer {
        width: min(42rem, calc(100% - 2rem));
        margin: 0 auto;
        padding: 0 0 2rem;
        color: var(--muted);
        text-align: center;
    }

    p {
        margin: 0;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
    }
</style>
