---
import type { MarkdownHeading } from 'astro';

interface Props {
	headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
	filtered.length > 1 && (
		<nav class="toc" aria-label="Table of contents">
			<p class="toc__title">On this page</p>
			<ol>
				{filtered.map((h) => (
					<li class:list={['toc__item', h.depth === 3 && 'toc__item--sub']}>
						<a href={`#${h.slug}`} data-toc-link>
							{h.text}
						</a>
					</li>
				))}
			</ol>
		</nav>
	)
}

<script>
	const observerOptions = {
		root: null,
		rootMargin: '-20px 0px -70% 0px',
		threshold: 0,
	};

	const tocLinks = document.querySelectorAll('[data-toc-link]');
	const headings = Array.from(document.querySelectorAll('.content h2, .content h3'));

	let activeId = '';

	const observer = new IntersectionObserver((entries) => {
		// Identify which heading is currently intersecting
		entries.forEach((entry) => {
			if (entry.isIntersecting) {
				activeId = entry.target.id;
			}
		});

		// Check if we are at the bottom of the page
		const scrollHeight = document.documentElement.scrollHeight;
		const scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
		const clientHeight = document.documentElement.clientHeight;

		if (scrollTop + clientHeight >= scrollHeight - 20) {
			activeId = headings[headings.length - 1]?.id || activeId;
		}

		updateActiveLink();
	}, observerOptions);

	function updateActiveLink() {
		if (!activeId) return;
		
		tocLinks.forEach((link) => {
			const href = link.getAttribute('href');
			if (href === `#${activeId}`) {
				link.classList.add('active');
			} else {
				link.classList.remove('active');
			}
		});
	}

	headings.forEach((heading) => observer.observe(heading));

	// Initial check on load
	window.addEventListener('scroll', () => {
		const scrollHeight = document.documentElement.scrollHeight;
		const scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
		const clientHeight = document.documentElement.clientHeight;

		if (scrollTop + clientHeight >= scrollHeight - 20) {
			activeId = headings[headings.length - 1]?.id || activeId;
			updateActiveLink();
		}
	}, { passive: true });
</script>

<style>
	.toc {
		margin-bottom: 2.5rem;
	}

	.toc__title {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
		margin-bottom: 1rem;
		margin-top: 0;
	}

	.toc ol {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.toc__item {
		margin-bottom: 0.5rem;
		font-size: 0.875rem;
	}

	.toc__item--sub {
		padding-left: 1rem;
	}

	.toc a {
		color: var(--muted);
		text-decoration: none;
		transition:
			color 160ms ease,
			border-left-color 160ms ease;
		display: block;
		border-left: 2px solid transparent;
		padding-left: 0.75rem;
		line-height: 1.4;
	}

	.toc a:hover,
	.toc a.active {
		color: var(--text);
	}

	.toc a.active {
		border-left-color: var(--accent);
		font-weight: 500;
	}
</style>
